+def _run_inference(config: dict, checkpoint_path: Path, output_path: Path) -> dict:
+    """Load probe bundle and generate predictions for submission."""
+    data_cfg = config.get("data", {})
+    paths_cfg = config.get("paths", {})
+    training_cfg = config.get("training", {})
+    data_root = (RUNTIME_ROOT / paths_cfg.get("data_root", "./birdclef-2026")).resolve()
+
+    cache_root_value = str(data_cfg.get("perch_cache_dir", "")).strip()
+    if not cache_root_value:
+        raise ValueError("data.perch_cache_dir is required for inference")
+    cache_root = (Path(cache_root_value).expanduser() if Path(cache_root_value).is_absolute()
+                  else (RUNTIME_ROOT / cache_root_value).resolve())
+
+    sample_submission_path = data_root / data_cfg.get("sample_submission_csv", "sample_submission.csv")
+    if not sample_submission_path.exists():
+        raise FileNotFoundError(f"sample_submission.csv not found at {sample_submission_path}")
+
+    sample_df = pd.read_csv(sample_submission_path)
+    labels = sample_df.columns[1:].tolist()
+
+    # Load probe bundle
+    with checkpoint_path.open("rb") as f:
+        bundle = pickle.load(f)
+
+    bundle_labels = bundle["labels"]
+    scaler = bundle["scaler"]
+    pca = bundle["pca"]
+    models = bundle["models"]
+    prior_tables = bundle["prior_tables"]
+    probe_use_raw_scores = bundle.get("probe_use_raw_scores", True)
+    probe_alpha = bundle.get("probe_alpha", 0.40)
+    mapping_ctx = bundle.get("mapping_context", {})
+    class_prototypes = bundle.get("class_prototypes", {})
+    class_family = bundle.get("class_family", {})
+    family_idx_map = bundle.get("family_idx_map", {})
+    gaussian_weights = np.array(bundle.get("gaussian_weights", [0.1, 0.2, 0.4, 0.2, 0.1]), dtype=np.float32)
+    final_gaussian_smoothing = bundle.get("final_gaussian_smoothing", True)
+    bundle_config = bundle.get("config", {})
+    windows_per_file = int(bundle_config.get("windows_per_file", 12))
+    lambda_event = float(training_cfg.get("prior_lambda_event", bundle_config.get("prior_lambda_event", 0.4)))
+    lambda_texture = float(training_cfg.get("prior_lambda_texture", bundle_config.get("prior_lambda_texture", 1.0)))
+    lambda_proxy_texture = float(training_cfg.get("prior_lambda_proxy_texture", bundle_config.get("prior_lambda_proxy_texture", 0.8)))
+    smooth_texture_alpha = float(training_cfg.get("smooth_texture_alpha", bundle_config.get("smooth_texture_alpha", 0.35)))
+    use_sequential_features = bool(bundle_config.get("use_sequential_features", True))
+    use_prototype_similarity = bool(bundle_config.get("use_prototype_similarity", True))
+    use_family_mean = bool(bundle_config.get("use_family_mean", True))
+
+    # Load test soundscape Perch cache
+    test_cache_meta = cache_root / "test_perch_meta.parquet"
+    test_cache_arrays = cache_root / "test_perch_arrays.npz"
+
+    if test_cache_meta.exists() and test_cache_arrays.exists():
+        meta_df = pd.read_parquet(test_cache_meta)
+        cached = np.load(test_cache_arrays)
+        raw_scores = cached["scores_full_raw"].astype(np.float32)
+        embeddings = cached["emb_full"].astype(np.float32)
+        row_ids = meta_df["row_id"].to_numpy()
+    else:
+        # Local dry-run: use train soundscape data
+        meta_path = cache_root / "full_perch_meta.parquet"
+        arrays_path = cache_root / "full_perch_arrays.npz"
+        if not meta_path.exists() or not arrays_path.exists():
+            raise FileNotFoundError(f"Missing cached Perch artifacts in {cache_root}")
+        meta_df = pd.read_parquet(meta_path)
+        cached = np.load(arrays_path)
+        raw_scores = cached["scores_full_raw"].astype(np.float32)
+        embeddings = cached["emb_full"].astype(np.float32)
+        row_ids = meta_df["row_id"].to_numpy()
+
+    # Build site/hour metadata
+    sites = meta_df["site"].fillna("unknown").astype(str).to_numpy() if "site" in meta_df.columns else np.array(["unknown"] * len(meta_df))
+    hours = meta_df["hour_utc"].fillna(-1).astype(int).to_numpy() if "hour_utc" in meta_df.columns else np.full(len(meta_df), -1, dtype=int)
+
+    # Reduce embeddings
+    reduced = pca.transform(scaler.transform(embeddings)).astype(np.float32)
+
+    # Apply Bayesian prior fusion
+    n_classes = len(labels)
+    if raw_scores.shape[1] != n_classes:
+        raw_scores_padded = np.zeros((len(raw_scores), n_classes), dtype=np.float32)
+        common = min(raw_scores.shape[1], n_classes)
+        raw_scores_padded[:, :common] = raw_scores[:, :common]
+        raw_scores = raw_scores_padded
+
+    base_scores = _fuse_scores(
+        raw_scores,
+        sites=sites,
+        hours=hours,
+        tables=prior_tables,
+        mapping_ctx=mapping_ctx,
+        lambda_event=lambda_event,
+        lambda_texture=lambda_texture,
+        lambda_proxy_texture=lambda_proxy_texture,
+        smooth_texture_alpha=smooth_texture_alpha,
+        windows_per_file=windows_per_file,
+    )
+
+    # Compute prior scores for feature building
+    prior_scores = _prior_logits(sites, hours, prior_tables)
+
+    # Apply per-class probe models
+    predictions = base_scores.copy()
+    for class_index, clf in models.items():
+        if class_index >= n_classes:
+            continue
+        proto_sim = None
+        if use_prototype_similarity and class_index in class_prototypes:
+            proto_sim = _cosine_sim_to_prototype(reduced, class_prototypes[class_index])
+        family_mean = (
+            _family_mean_features(class_index, predictions, class_family, family_idx_map)
+            if use_family_mean else None
+        )
+        features = _build_class_features(
+            reduced,
+            raw_scores_col=raw_scores[:, class_index],
+            prior_scores_col=prior_scores[:, class_index],
+            base_scores_col=base_scores[:, class_index],
+            windows_per_file=windows_per_file,
+            use_raw_scores=probe_use_raw_scores,
+            use_sequential_features=use_sequential_features,
+            prototype_similarity=proto_sim,
+            family_mean=family_mean,
+        )
+        probe_logits = clf.decision_function(features).astype(np.float32)
+        predictions[:, class_index] = (
+            (1.0 - probe_alpha) * base_scores[:, class_index] + probe_alpha * probe_logits
+        )
+
+    if final_gaussian_smoothing:
+        predictions = _gaussian_smooth(predictions, gaussian_weights, windows_per_file)
+
+    # Sigmoid to get probabilities
+    predictions = 1.0 / (1.0 + np.exp(-predictions.astype(np.float64)))
+    predictions = predictions.astype(np.float32)
+
+    # Build submission CSV
+    submission_rows = []
+    for i, row_id in enumerate(row_ids):
+        row = [row_id] + [f"{predictions[i, j]:.4f}" for j in range(n_classes)]
+        submission_rows.append(row)
+
+    with output_path.open("w", encoding="utf-8", newline="") as f:
+        import csv as csv_mod
+        writer = csv_mod.writer(f)
+        writer.writerow(["row_id"] + labels)
+        writer.writerows(submission_rows)
+
+    return {"output": str(output_path), "rows": len(submission_rows), "classes": n_classes}
+
+
